# Handle line endings automatically for files detected as text
# and leave binary files untouched
* text=auto

# Enforce LF for all Java and standard text files
*.java text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.txt text eol=lf

# Explicitly mark icons as binary
*.png binary
*.PNG binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
